# Zotero DataCheck — 开发环境配置
# 复制本文件为 .env 并填写实际路径

# ── 开发用 Zotero 配置（npm start 使用） ──
# Zotero profile 目录，例如 C:\Users\<you>\AppData\Roaming\Zotero\Profiles\xxxxxxxx.default
ZOTERO_PLUGIN_PROFILE_PATH=

# 如果 Zotero 启用了自定义数据目录，填写此项
# ZOTERO_PLUGIN_DATA_DIR=

# ── 测试数据种子（npm test 使用，可选） ──
# 指定专用的测试 profile/data 快照目录，优先级高于上面的开发路径
# ZOTERO_PLUGIN_TEST_PROFILE_SEED_PATH=
# ZOTERO_PLUGIN_TEST_DATA_SEED_PATH=

# ── 本地真实 PDF 回归测试（npm test 使用，可选，默认跳过） ──
# 按标题关键字匹配一个 PDF 附件，并真的打开 reader 跑整篇表格扫描
# 例如：ZOTERO_PLUGIN_TEST_PDF_TITLE_QUERY=TokenFlow
# ZOTERO_PLUGIN_TEST_PDF_TITLE_QUERY=
# ZOTERO_PLUGIN_TEST_PDF_MIN_TABLES=1
# ZOTERO_PLUGIN_TEST_PDF_MIN_COLUMNS=4

audit-summary = Parsed { $rows } rows x { $cols } columns ({ $dataRows } data rows, { $numericCells } numeric cells) and produced { $findings } finding(s).
audit-detector-duplicate-rows-summary-hit = Detected { $count } repeated row pattern(s).
audit-detector-duplicate-rows-summary-clear = No repeated rows detected.
audit-detector-duplicate-rows-finding = Rows { $rows } contain identical cell text: { $signature }.
audit-detector-near-duplicate-rows-summary-hit = Flagged { $count } near-duplicate row pair(s).
audit-detector-near-duplicate-rows-summary-clear = No near-duplicate rows detected.
audit-detector-near-duplicate-rows-finding = Rows { $left } and { $right } match in { $matched } of { $total } populated cells and differ only at { $columns }.
audit-detector-duplicate-numeric-summary-hit = Detected { $count } repeated numeric sequence(s).
audit-detector-duplicate-numeric-summary-clear = No repeated numeric sequences detected.
audit-detector-duplicate-numeric-finding = Rows { $rows } share the same numeric sequence: { $signature }.
audit-detector-invalid-percentages-summary-hit = Detected { $count } out-of-range percentage value(s).
audit-detector-invalid-percentages-summary-clear = No out-of-range percentage values detected.
audit-detector-invalid-percentages-finding = Cell { $cell } has an out-of-range percentage value: { $value }.
audit-detector-invalid-pvalues-summary-hit = Detected { $count } out-of-range p-value(s).
audit-detector-invalid-pvalues-summary-clear = No out-of-range p-values detected.
audit-detector-invalid-pvalues-finding = Cell { $cell } has an out-of-range p-value: { $value }.
audit-detector-repeated-columns-summary-hit = Detected { $count } repeated numeric column pattern(s).
audit-detector-repeated-columns-summary-clear = No repeated numeric columns detected.
audit-detector-repeated-columns-finding = Columns { $columns } share the same numeric series across { $rows } data row(s): { $signature }.
audit-detector-uniform-columns-summary-hit = Flagged { $count } numeric column(s) with dominant repeated values.
audit-detector-uniform-columns-summary-clear = No dominant repeated numeric columns detected.
audit-detector-uniform-columns-finding = Column { $column } repeats { $value } in { $count } of { $total } numeric cell(s).
audit-detector-benford-summary-skip = Only { $count } plain numeric values are available, below the Benford minimum sample size of { $minimum }.
audit-detector-benford-summary-hit = Leading digit frequencies deviate from the Benford expectation (MAD { $mad }, sample size { $count }).
audit-detector-benford-summary-clear = Leading digit frequencies are broadly consistent with the Benford expectation (MAD { $mad }, sample size { $count }).
audit-detector-benford-finding = Leading digit frequencies deviate from the Benford expectation, with the largest gaps at digits { $digits } (MAD { $mad }, sample size { $count }).
audit-detector-benford-digit-detail = { $digit } (observed { $observed }, expected { $expected })
audit-detector-second-digit-benford-summary-skip = Only { $count } plain numeric values are available for second-digit Benford analysis, below the minimum sample size of { $minimum }.
audit-detector-second-digit-benford-summary-hit = Second-digit frequencies deviate from the Benford expectation (MAD { $mad }, sample size { $count }).
audit-detector-second-digit-benford-summary-clear = Second-digit frequencies are broadly consistent with the Benford expectation (MAD { $mad }, sample size { $count }).
audit-detector-second-digit-benford-finding = Second-digit frequencies deviate from the Benford expectation, with the largest gaps at digits { $digits } (MAD { $mad }, sample size { $count }).
audit-detector-terminal-digit-summary-skip = Only { $count } terminal digits are available, below the minimum sample size of { $minimum }.
audit-detector-terminal-digit-summary-hit = Terminal digit frequencies are unusually concentrated (chi-square { $chiSquare }, sample size { $count }).
audit-detector-terminal-digit-summary-clear = Terminal digit frequencies do not show a strong preference pattern (chi-square { $chiSquare }, sample size { $count }).
audit-detector-terminal-digit-finding = Terminal digits are concentrated in { $digits } (chi-square { $chiSquare }, digits 0 and 5 share { $zeroFive }, sample size { $count }).
audit-detector-rounding-heaping-summary-skip = Not enough consistently formatted values are available for rounding/heaping checks (minimum subgroup size { $minimum }).
audit-detector-rounding-heaping-summary-hit = Flagged { $count } rounding/heaping pattern(s).
audit-detector-rounding-heaping-summary-clear = No strong rounding/heaping patterns detected.
audit-detector-rounding-heaping-finding-integer = Integer-formatted values cluster on multiples of 5 in { $count } of { $total } samples ({ $ratio }).
audit-detector-rounding-heaping-finding-decimal = Decimal-formatted values cluster on .0/.00/.5/.50 in { $count } of { $total } samples ({ $ratio }).
audit-detector-pvalue-clustering-summary-skip = Only { $count } exact p-values fall inside the 0.04-0.06 inspection window, below the minimum of { $minimum }.
audit-detector-pvalue-clustering-summary-hit = Exact p-values cluster around the 0.05 threshold inside the inspection window (n = { $count }).
audit-detector-pvalue-clustering-summary-clear = Exact p-values do not show a strong 0.05 threshold cluster in the inspection window (n = { $count }).
audit-detector-pvalue-clustering-finding = In the 0.04-0.06 window, { $below } p-value(s) fall just below 0.05, { $exact } equal 0.05, and { $above } fall just above 0.05 (total { $total }).
audit-detector-low-variance-columns-summary-hit = Flagged { $count } low-variance numeric column(s).
audit-detector-low-variance-columns-summary-clear = No low-variance numeric columns detected.
audit-detector-low-variance-columns-finding = Column { $column } is unusually tight across { $count } values (CV { $cv }, normalized range { $range }).
parser-warning-too-few-lines = The selection contains fewer than two non-empty lines, so the table shape is unstable.
parser-warning-no-delimiter = A stable multi-column delimiter could not be inferred from the selected text.
parser-warning-single-column = The normalized selection only produced a single column.
parser-warning-missing-cells = Some rows still contain missing cells after column alignment.
reader-diagnostic-preserved-selection = The live reader selection was cleared when the command opened, so DataCheck reused the preserved selection snapshot.
reader-diagnostic-page-view-unavailable = Selection geometry is available, but the current PDF page view is not ready.
reader-diagnostic-text-layer-unavailable = Selection geometry is available, but the PDF text layer is not available.
reader-diagnostic-viewport-unavailable = Selection geometry is available, but the PDF viewport transform is not available.
reader-diagnostic-no-text-spans = Selection geometry is available, but no matching text-layer spans were found.
reader-diagnostic-grid-fallback = Selection geometry did not produce a stable row/column grid, so DataCheck fell back to plain-text parsing.
reader-diagnostic-geometry-rows = Geometry extracted { $rows } visual row(s) from { $rects } selection rectangle(s).
reader-diagnostic-geometry-columns = Structured extraction reconstructed up to { $cols } column(s) from the PDF text layer.
reader-diagnostic-pdf-document-unavailable = PDF text content is not ready yet, so full-document table scanning is currently unavailable.
reader-diagnostic-pdf-page-scan-error = DataCheck could not scan page { $page } while searching for tables.
reader-diagnostic-pdf-table-detected = Full-document scan found table { $index } on page { $page } with { $rows } row(s) and up to { $cols } column(s).
